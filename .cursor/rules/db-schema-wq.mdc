---
alwaysApply: false
---
-- =============================================================================
-- SERIOUS GAME MVP DATABASE SCHEMA
-- Optimized for Supabase + PostgreSQL
-- =============================================================================

-- Enable UUID extension
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Create ENUMS for type safety
CREATE TYPE user_role AS ENUM ('admin', 'teacher', 'student');
CREATE TYPE game_type AS ENUM ('image_term_match', 'image_marker', 'line_picker', 'custom');
CREATE TYPE file_type AS ENUM ('image', 'pdf', 'video', 'audio', 'document');
CREATE TYPE game_status AS ENUM ('draft', 'published', 'archived');

-- =============================================================================
-- 1. PROFILES (extends Supabase auth.users)
-- =============================================================================
CREATE TABLE profiles (
    id UUID REFERENCES auth.users(id) ON DELETE CASCADE PRIMARY KEY,
    username TEXT UNIQUE NOT NULL,
    display_name TEXT,
    description TEXT,
    avatar_url TEXT,
    linkedin_url TEXT,
    role user_role NOT NULL DEFAULT 'student',
    follow_count INTEGER DEFAULT 0,
    is_onboarded BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS Policies for profiles
ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can view public profile info" ON profiles
    FOR SELECT USING (true);

CREATE POLICY "Users can update own profile" ON profiles
    FOR UPDATE USING (auth.uid() = user_id);

CREATE POLICY "Users can insert own profile" ON profiles
    FOR INSERT WITH CHECK (auth.uid() = user_id);

-- =============================================================================
-- 2. INSTITUTIONS
-- =============================================================================
CREATE TABLE institutions (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    name TEXT NOT NULL,
    description TEXT,
    email TEXT,
    address JSONB, -- {street, city, country, postal_code}
    website TEXT,
    social_links JSONB, -- {twitter, facebook, instagram, linkedin}
    created_by_admin_id UUID REFERENCES profiles(user_id) ON DELETE SET NULL,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for institutions
ALTER TABLE institutions ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Everyone can view institutions" ON institutions
    FOR SELECT USING (true);

CREATE POLICY "Admins can manage institutions" ON institutions
    FOR ALL USING (
        EXISTS (
            SELECT 1 FROM profiles 
            WHERE profiles.user_id = auth.uid() 
            AND profiles.role = 'admin'
        )
    );

-- =============================================================================
-- 3. USER_INSTITUTIONS (Many-to-Many)
-- =============================================================================
CREATE TABLE user_institutions (
    user_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE,
    institution_id UUID REFERENCES institutions(id) ON DELETE CASCADE,
    joined_at TIMESTAMPTZ DEFAULT NOW(),
    PRIMARY KEY (user_id, institution_id)
);

-- RLS for user_institutions
ALTER TABLE user_institutions ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can view their institution relationships" ON user_institutions
    FOR SELECT USING (auth.uid() = user_id);

CREATE POLICY "Users can manage their institution relationships" ON user_institutions
    FOR ALL USING (auth.uid() = user_id);

-- =============================================================================
-- 4. TEACHER_FOLLOWERS (Many-to-Many)
-- =============================================================================
CREATE TABLE teacher_followers (
    teacher_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE,
    student_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE,
    followed_at TIMESTAMPTZ DEFAULT NOW(),
    PRIMARY KEY (teacher_id, student_id),
    CHECK (teacher_id != student_id) -- Prevent self-following
);

-- RLS for teacher_followers
ALTER TABLE teacher_followers ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Students can manage who they follow" ON teacher_followers
    FOR ALL USING (auth.uid() = student_id);

CREATE POLICY "Teachers can see their followers" ON teacher_followers
    FOR SELECT USING (auth.uid() = teacher_id);

-- =============================================================================
-- 5. COURSES
-- =============================================================================
CREATE TABLE courses (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    teacher_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE NOT NULL,
    institution_id UUID REFERENCES institutions(id) ON DELETE SET NULL,
    is_published BOOLEAN DEFAULT false,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for courses
ALTER TABLE courses ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Teachers can manage own courses" ON courses
    FOR ALL USING (auth.uid() = teacher_id);

CREATE POLICY "Students can view published courses from followed teachers" ON courses
    FOR SELECT USING (
        is_published = true AND (
            teacher_id IN (
                SELECT teacher_id FROM teacher_followers 
                WHERE student_id = auth.uid()
            )
        )
    );

-- =============================================================================
-- 6. COURSE_ENROLLMENTS (Many-to-Many)
-- =============================================================================
CREATE TABLE course_enrollments (
    course_id UUID REFERENCES courses(id) ON DELETE CASCADE,
    student_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE,
    enrolled_at TIMESTAMPTZ DEFAULT NOW(),
    PRIMARY KEY (course_id, student_id)
);

-- RLS for course_enrollments
ALTER TABLE course_enrollments ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Students can manage their enrollments" ON course_enrollments
    FOR ALL USING (auth.uid() = student_id);

CREATE POLICY "Teachers can see enrollments for their courses" ON course_enrollments
    FOR SELECT USING (
        course_id IN (
            SELECT id FROM courses WHERE teacher_id = auth.uid()
        )
    );

-- =============================================================================
-- 7. TOPICS
-- =============================================================================
CREATE TABLE topics (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    course_id UUID REFERENCES courses(id) ON DELETE CASCADE NOT NULL,
    order_index INTEGER DEFAULT 0,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for topics
ALTER TABLE topics ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Teachers can manage topics in their courses" ON topics
    FOR ALL USING (
        course_id IN (
            SELECT id FROM courses WHERE teacher_id = auth.uid()
        )
    );

CREATE POLICY "Students can view topics in enrolled courses" ON topics
    FOR SELECT USING (
        course_id IN (
            SELECT course_id FROM course_enrollments 
            WHERE student_id = auth.uid()
        )
    );

-- =============================================================================
-- 8. LESSONS (Yoopta.dev JSON content)
-- =============================================================================
CREATE TABLE lessons (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    title TEXT NOT NULL,
    topic_id UUID REFERENCES topics(id) ON DELETE CASCADE NOT NULL,
    content JSONB NOT NULL, -- Yoopta.dev editor JSON
    order_index INTEGER DEFAULT 0,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for lessons (inherit from topics)
ALTER TABLE lessons ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Teachers can manage lessons in their topics" ON lessons
    FOR ALL USING (
        topic_id IN (
            SELECT t.id FROM topics t
            JOIN courses c ON t.course_id = c.id
            WHERE c.teacher_id = auth.uid()
        )
    );

CREATE POLICY "Students can view lessons in enrolled courses" ON lessons
    FOR SELECT USING (
        topic_id IN (
            SELECT t.id FROM topics t
            JOIN courses c ON t.course_id = c.id
            JOIN course_enrollments ce ON c.id = ce.course_id
            WHERE ce.student_id = auth.uid()
        )
    );

-- =============================================================================
-- 9. MEDIA_FILES (File uploads via Supabase Storage)
-- =============================================================================
CREATE TABLE media_files (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    file_path TEXT NOT NULL, -- Supabase Storage path
    file_type file_type NOT NULL,
    file_size_bytes BIGINT,
    uploader_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE NOT NULL,
    entity_type TEXT, -- 'course', 'topic', 'lesson', 'game'
    entity_id UUID, -- Related entity ID
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for media_files
ALTER TABLE media_files ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can manage their uploaded files" ON media_files
    FOR ALL USING (auth.uid() = uploader_id);

-- =============================================================================
-- 10. GAMES (React Flow game configurations)
-- =============================================================================
CREATE TABLE games (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    game_type game_type NOT NULL,
    teacher_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE NOT NULL,
    topic_id UUID REFERENCES topics(id) ON DELETE CASCADE,
    game_config JSONB NOT NULL, -- React Flow nodes/edges + game settings
    status game_status DEFAULT 'draft',
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- RLS for games
ALTER TABLE games ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Teachers can manage their games" ON games
    FOR ALL USING (auth.uid() = teacher_id);

CREATE POLICY "Students can view published games from enrolled courses" ON games
    FOR SELECT USING (
        status = 'published' AND
        topic_id IN (
            SELECT t.id FROM topics t
            JOIN courses c ON t.course_id = c.id
            JOIN course_enrollments ce ON c.id = ce.course_id
            WHERE ce.student_id = auth.uid()
        )
    );

-- =============================================================================
-- 11. GAME_SESSIONS (Student gameplay tracking)
-- =============================================================================
CREATE TABLE game_sessions (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,
    game_id UUID REFERENCES games(id) ON DELETE CASCADE NOT NULL,
    student_id UUID REFERENCES profiles(user_id) ON DELETE CASCADE NOT NULL,
    score INTEGER DEFAULT 0,
    completed BOOLEAN DEFAULT false,
    session_data JSONB, -- Game-specific progress/answers
    started_at TIMESTAMPTZ DEFAULT NOW(),
    completed_at TIMESTAMPTZ
);

-- RLS for game_sessions
ALTER TABLE game_sessions ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Students can manage their game sessions" ON game_sessions
    FOR ALL USING (auth.uid() = student_id);

CREATE POLICY "Teachers can view sessions for their games" ON game_sessions
    FOR SELECT USING (
        game_id IN (
            SELECT id FROM games WHERE teacher_id = auth.uid()
        )
    );

-- =============================================================================
-- INDEXES FOR PERFORMANCE
-- =============================================================================
CREATE INDEX idx_profiles_role ON profiles(role);
CREATE INDEX idx_profiles_username ON profiles(username);
CREATE INDEX idx_courses_teacher ON courses(teacher_id);
CREATE INDEX idx_courses_published ON courses(is_published);
CREATE INDEX idx_topics_course ON topics(course_id);
CREATE INDEX idx_lessons_topic ON lessons(topic_id);
CREATE INDEX idx_games_teacher ON games(teacher_id);
CREATE INDEX idx_games_topic ON games(topic_id);
CREATE INDEX idx_games_status ON games(status);
CREATE INDEX idx_game_sessions_student ON game_sessions(student_id);
CREATE INDEX idx_game_sessions_game ON game_sessions(game_id);

-- =============================================================================
-- FUNCTIONS & TRIGGERS
-- =============================================================================

-- Auto-update updated_at timestamps
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Apply to relevant tables
CREATE TRIGGER profiles_updated_at BEFORE UPDATE ON profiles FOR EACH ROW EXECUTE FUNCTION update_updated_at();
CREATE TRIGGER institutions_updated_at BEFORE UPDATE ON institutions FOR EACH ROW EXECUTE FUNCTION update_updated_at();
CREATE TRIGGER courses_updated_at BEFORE UPDATE ON courses FOR EACH ROW EXECUTE FUNCTION update_updated_at();
CREATE TRIGGER topics_updated_at BEFORE UPDATE ON topics FOR EACH ROW EXECUTE FUNCTION update_updated_at();
CREATE TRIGGER lessons_updated_at BEFORE UPDATE ON lessons FOR EACH ROW EXECUTE FUNCTION update_updated_at();
CREATE TRIGGER games_updated_at BEFORE UPDATE ON games FOR EACH ROW EXECUTE FUNCTION update_updated_at();

-- Update follow_count when followers change
CREATE OR REPLACE FUNCTION update_teacher_follow_count()
RETURNS TRIGGER AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        UPDATE profiles SET follow_count = follow_count + 1 WHERE id = NEW.teacher_id;
        RETURN NEW;
    ELSIF TG_OP = 'DELETE' THEN
        UPDATE profiles SET follow_count = follow_count - 1 WHERE id = OLD.teacher_id;
        RETURN OLD;
    END IF;
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER teacher_followers_count 
    AFTER INSERT OR DELETE ON teacher_followers
    FOR EACH ROW EXECUTE FUNCTION update_teacher_follow_count();



-- Enhanced games table
ALTER TABLE games ADD COLUMN IF NOT EXISTS version INTEGER DEFAULT 1;
ALTER TABLE games ADD COLUMN IF NOT EXISTS published_version INTEGER; -- Snapshot of published version
ALTER TABLE games ADD COLUMN IF NOT EXISTS is_draft BOOLEAN DEFAULT true;
ALTER TABLE games ADD COLUMN IF NOT EXISTS published_at TIMESTAMPTZ;
ALTER TABLE games ADD COLUMN IF NOT EXISTS game_config JSONB; -- Store nodes + edges workflow


-- New table: game_versions (for version history)
CREATE TABLE IF NOT EXISTS game_versions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  game_id UUID NOT NULL REFERENCES games(id) ON DELETE CASCADE,
  version INTEGER NOT NULL,
  game_config JSONB NOT NULL,
  published_at TIMESTAMPTZ,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(game_id, version)
);

-- Enhanced game_sessions (link to specific version)
ALTER TABLE game_sessions ADD COLUMN IF NOT EXISTS game_version INTEGER;
ALTER TABLE game_sessions ADD COLUMN IF NOT EXISTS current_node_id TEXT; -- Track progress
ALTER TABLE game_sessions ADD COLUMN IF NOT EXISTS progress_data JSONB; -- Store answers, scores per node

-- Step 1: Drop the existing policy that depends on topic_id
DROP POLICY IF EXISTS "Students can view published games from enrolled courses" ON games;

-- Step 2: Create a new policy that allows students to view published games
-- from teachers in their institution (no course/topic dependency)
CREATE POLICY "Students can view published games from their institution"
ON games
FOR SELECT
TO authenticated
USING (
  -- Students can view published games from teachers in their institution
  status = 'published' 
  AND institution_id IN (
    SELECT institution_id 
    FROM profiles 
    WHERE user_id = auth.uid() 
    AND role = 'student'
  )
);

-- Step 3: Ensure teachers can manage their own games
CREATE POLICY IF NOT EXISTS "Teachers can manage their own games"
ON games
FOR ALL
TO authenticated
USING (
  teacher_id = auth.uid()
  AND EXISTS (
    SELECT 1 
    FROM profiles 
    WHERE user_id = auth.uid() 
    AND role = 'teacher'
  )
);

-- Step 4: Now safely drop the topic_id column
ALTER TABLE games DROP COLUMN IF EXISTS topic_id;