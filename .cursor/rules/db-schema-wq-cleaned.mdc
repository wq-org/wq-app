CREATE TABLE public.course_enrollments (
  course_id uuid NOT NULL,
  student_id uuid NOT NULL,
  enrolled_at timestamp with time zone DEFAULT now(),
  CONSTRAINT course_enrollments_pkey PRIMARY KEY (course_id, student_id),
  CONSTRAINT course_enrollments_course_id_fkey FOREIGN KEY (course_id) REFERENCES public.courses(id),
  CONSTRAINT course_enrollments_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.courses (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  title text NOT NULL,
  description text,
  teacher_id uuid NOT NULL,
  institution_id uuid,
  is_published boolean DEFAULT false,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT courses_pkey PRIMARY KEY (id),
  CONSTRAINT courses_teacher_id_fkey FOREIGN KEY (teacher_id) REFERENCES public.profiles(user_id),
  CONSTRAINT courses_institution_id_fkey FOREIGN KEY (institution_id) REFERENCES public.institutions(id)
);
CREATE TABLE public.game_sessions (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  game_id uuid NOT NULL,
  student_id uuid NOT NULL,
  score integer DEFAULT 0,
  completed boolean DEFAULT false,
  session_data jsonb,
  started_at timestamp with time zone DEFAULT now(),
  completed_at timestamp with time zone,
  game_version integer,
  current_node_id text,
  progress_data jsonb,
  CONSTRAINT game_sessions_pkey PRIMARY KEY (id),
  CONSTRAINT game_sessions_game_id_fkey FOREIGN KEY (game_id) REFERENCES public.games(id),
  CONSTRAINT game_sessions_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.game_versions (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  game_id uuid NOT NULL,
  version integer NOT NULL,
  game_config jsonb NOT NULL,
  published_at timestamp with time zone,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT game_versions_pkey PRIMARY KEY (id),
  CONSTRAINT game_versions_game_id_fkey FOREIGN KEY (game_id) REFERENCES public.games(id)
);
CREATE TABLE public.games (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  title text NOT NULL,
  description text,
  game_type USER-DEFINED NOT NULL,
  teacher_id uuid NOT NULL,
  topic_id uuid,
  game_config jsonb NOT NULL,
  status USER-DEFINED DEFAULT 'draft'::game_status,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  version integer DEFAULT 1,
  published_version integer,
  is_draft boolean DEFAULT true,
  published_at timestamp with time zone,
  CONSTRAINT games_pkey PRIMARY KEY (id),
  CONSTRAINT games_teacher_id_fkey FOREIGN KEY (teacher_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.institutions (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  name text NOT NULL,
  description text,
  email text,
  address jsonb,
  website text,
  social_links jsonb,
  created_by_admin_id uuid,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  image_url text,
  CONSTRAINT institutions_pkey PRIMARY KEY (id),
  CONSTRAINT institutions_created_by_admin_id_fkey FOREIGN KEY (created_by_admin_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.lessons (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  title text NOT NULL,
  topic_id uuid NOT NULL,
  content jsonb NOT NULL,
  order_index integer DEFAULT 0,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  description text,
  CONSTRAINT lessons_pkey PRIMARY KEY (id),
  CONSTRAINT lessons_topic_id_fkey FOREIGN KEY (topic_id) REFERENCES public.topics(id)
);
CREATE TABLE public.media_files (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  title text NOT NULL,
  description text,
  file_path text NOT NULL,
  file_type USER-DEFINED NOT NULL,
  file_size_bytes bigint,
  uploader_id uuid NOT NULL,
  entity_type USER-DEFINED,
  entity_id uuid,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT media_files_pkey PRIMARY KEY (id),
  CONSTRAINT media_files_uploader_id_fkey FOREIGN KEY (uploader_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.profiles (
  user_id uuid NOT NULL,
  username text,
  email text,
  role text,
  two_fa_enabled boolean,
  two_fa_secret text,
  created_at timestamp with time zone,
  updated_at timestamp with time zone,
  last_login timestamp with time zone,
  linkedin_url text NOT NULL DEFAULT ''::text,
  avatar_url text,
  follow_count integer DEFAULT 0,
  is_onboarded boolean DEFAULT false,
  display_name text,
  description text,
  CONSTRAINT profiles_pkey PRIMARY KEY (user_id),
  CONSTRAINT fk_profiles_user FOREIGN KEY (user_id) REFERENCES auth.users(id)
);
CREATE TABLE public.teacher_followers (
  teacher_id uuid NOT NULL,
  student_id uuid NOT NULL,
  followed_at timestamp with time zone DEFAULT now(),
  CONSTRAINT teacher_followers_pkey PRIMARY KEY (teacher_id, student_id),
  CONSTRAINT teacher_followers_teacher_id_fkey FOREIGN KEY (teacher_id) REFERENCES public.profiles(user_id),
  CONSTRAINT teacher_followers_student_id_fkey FOREIGN KEY (student_id) REFERENCES public.profiles(user_id)
);
CREATE TABLE public.topics (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  title text NOT NULL,
  description text,
  course_id uuid NOT NULL,
  order_index integer DEFAULT 0,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT topics_pkey PRIMARY KEY (id),
  CONSTRAINT topics_course_id_fkey FOREIGN KEY (course_id) REFERENCES public.courses(id)
);
CREATE TABLE public.user_institutions (
  user_id uuid NOT NULL,
  institution_id uuid NOT NULL,
  joined_at timestamp with time zone DEFAULT now(),
  CONSTRAINT user_institutions_pkey PRIMARY KEY (user_id, institution_id),
  CONSTRAINT user_institutions_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.profiles(user_id),
  CONSTRAINT user_institutions_institution_id_fkey FOREIGN KEY (institution_id) REFERENCES public.institutions(id)
);