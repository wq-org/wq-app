# Used by npm run format:sql (sqlfluff fix), not by npm run lint:sql.
# Baseline migrations excluded from SQLFluff: see .sqlfluffignore (security-sensitive files must not be auto-touched).
# Tooling split (see docs/architecture/db_design_principles.md — migrations tooling):
# - SQLFluff fix: optional layout/spacing/capitalisation when you choose to format migrations.
# - npm run lint:sql: scripts/check_sql_naming.py only (trg_/idx_/fk_/uq_/chk_/policies, banned abbreviations).
# - Manual / review: RLS correctness, tenant columns, FORCE ROW LEVEL SECURITY, GDPR/data lifecycle, migration order.
#
# Supabase migrations often mix PL/pgSQL ($$ blocks), triggers, and storage policies; SQLFluff’s Postgres
# dialect can be strict on indentation and aliasing inside function bodies — excluded rules below keep CI stable.
# ST06 (SELECT *) is disabled for migrations because NEW/OLD and compact triggers commonly use SELECT *.
# LT01: allow column-aligned CREATE TABLE / seed layout (single-space reflow would churn migrations).
# CP02: PL/pgSQL uses uppercase NEW/OLD; identifier lower-case rule fights that.
# CP01 / CP04: RLS policies often use lowercase using/with check and true/false; keep readable hand-written style.
# LT12 (single trailing newline) stays enabled — ensure files end with one \\n (editor or sqlfluff fix).
# Reference: https://docs.sqlfluff.com/en/stable/

[sqlfluff]
large_file_skip_byte_limit = 50000
dialect = postgres
max_line_length = 100
exclude_rules = LT05, LT02, LT01, AL01, RF03, ST06, CP01, CP02, CP04
sql_file_exts = .sql

[sqlfluff:indentation]
tab_space_size = 2
indented_joins = True
indented_using_on = True

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper
